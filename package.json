{
  "name": "module-splitting-loader",
  "version": "0.1.0",
  "description": "A webpack/rspack loader that splits ES modules into smaller parts for better tree-shaking",
  "license": "MIT",
  "author": "jserfeng",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "test": "rstest run"
  },
  "devDependencies": {
    "@rslib/core": "^0.20.0",
    "@rspack/core": "^2.0.0-beta.7",
    "@rstest/core": "^0.9.3",
    "@swc/core": "^1.15.18",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@swc/core": ">=1.3.0"
  },
  "packageManager": "pnpm@9.15.9"
}
